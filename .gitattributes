# UE5 recommended Git LFS attributes

# Source files — text, normalize line endings
*.cpp text eol=lf
*.h text eol=lf
*.cs text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.uproject text eol=lf
*.uplugin text eol=lf

# Binary assets — Git LFS
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap filter=lfs diff=lfs merge=lfs -text
*.ubulk filter=lfs diff=lfs merge=lfs -text
*.uexp filter=lfs diff=lfs merge=lfs -text
*.uptnl filter=lfs diff=lfs merge=lfs -text

# Other binary formats
*.png binary
*.jpg binary
*.jpeg binary
*.tga binary
*.bmp binary
*.ico binary
*.ttf binary
*.otf binary
*.wav binary
*.mp3 binary
*.ogg binary
*.fbx binary
*.psd binary
